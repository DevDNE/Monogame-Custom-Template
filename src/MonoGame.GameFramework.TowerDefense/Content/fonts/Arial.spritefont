<?xml version="1.0" encoding="utf-8"?>
<XnaContent xmlns:Graphics="Microsoft.Xna.Framework.Content.Pipeline.Graphics">
  <Asset Type="Graphics:FontDescription">
    <FontName>Arial</FontName>
    <Size>20</Size>
    <Spacing>0</Spacing>
    <UseKerning>true</UseKerning>
    <Style>Regular</Style>
    <CharacterRegions>
      <!-- Printable ASCII: U+0020 space .. U+007E tilde -->
      <CharacterRegion>
        <Start>&#32;</Start>
        <End>&#126;</End>
      </CharacterRegion>
      <!-- Latin-1 Supplement: U+00A0 nbsp .. U+00FF accented letters (covers most Western European text) -->
      <CharacterRegion>
        <Start>&#160;</Start>
        <End>&#255;</End>
      </CharacterRegion>
      <!-- Common typographic punctuation: U+2013 en-dash, U+2014 em-dash, U+2018 ‘ .. U+201D ” curly quotes, U+2026 ellipsis -->
      <CharacterRegion>
        <Start>&#8211;</Start>
        <End>&#8212;</End>
      </CharacterRegion>
      <CharacterRegion>
        <Start>&#8216;</Start>
        <End>&#8217;</End>
      </CharacterRegion>
      <CharacterRegion>
        <Start>&#8220;</Start>
        <End>&#8221;</End>
      </CharacterRegion>
      <CharacterRegion>
        <Start>&#8226;</Start>
        <End>&#8226;</End>
      </CharacterRegion>
      <CharacterRegion>
        <Start>&#8230;</Start>
        <End>&#8230;</End>
      </CharacterRegion>
    </CharacterRegions>
  </Asset>
</XnaContent>
